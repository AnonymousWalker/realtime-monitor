<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#16213e">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_stream_url_title"
        android:textColor="#ffffff"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_stream_url_hint"
        android:textColor="#a0a0a0"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <TextView
        android:id="@+id/tvStreamUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#e94560"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:gravity="center"
        android:padding="12dp"
        android:background="#1a1a2e"
        android:layout_marginBottom="16dp" />

    <ImageView
        android:id="@+id/ivQrCode"
        android:layout_width="256dp"
        android:layout_height="256dp"
        android:layout_gravity="center_horizontal"
        android:contentDescription="@string/qr_code_content_description"
        android:padding="16dp"
        android:background="#ffffff" />

    <Button
        android:id="@+id/btnCopyUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_copy_url"
        android:layout_marginTop="16dp" />

</LinearLayout>
